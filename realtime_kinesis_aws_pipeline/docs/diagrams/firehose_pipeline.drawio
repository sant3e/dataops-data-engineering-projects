        <mxCell id="fh-features" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#DC4405;strokeWidth=0.8;dashed=1;dashPattern=4 2;fontSize=10;fontFamily=Helvetica;fontColor=#232F3E;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" value="&lt;b style=&quot;color:#DC4405&quot;&gt;Firehose Features&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color:#000000;font-size:9px&quot;&gt;✓ Zero code — fully managed&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color:#000000;font-size:9px&quot;&gt;✓ Auto retry on failures&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color:#000000;font-size:9px&quot;&gt;✓ JSON to Parquet conversion&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color:#000000;font-size:9px&quot;&gt;✓ Scales automatically&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color:#000000;font-size:9px&quot;&gt;✓ 60s buffer / 5MB flush&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color:#000000;font-size:9px&quot;&gt;✓ YYYY/MM/DD/HH partitioning&lt;/span&gt;&lt;/div&gt;" vertex="1">
