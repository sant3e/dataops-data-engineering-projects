        <mxCell id="legend-step-2-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;DELIVER &amp;mdash; Kinesis Firehose + S3 (Raw)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #000000;&quot;&gt;&lt;b&gt;- &lt;/b&gt;Kinesis Data Firehose buffers and delivers records to S3&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #000000;&quot;&gt;&lt;b&gt;- &lt;/b&gt;Raw layer stores unprocessed ride events as Parquet&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-step-2-group">
