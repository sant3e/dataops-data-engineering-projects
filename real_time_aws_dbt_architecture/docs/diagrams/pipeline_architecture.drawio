        <mxCell id="legend-step-1-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;INGEST &amp;mdash; EC2 + MSK&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #000000;&quot;&gt;&lt;b&gt;- &lt;/b&gt;EC2 Kafka producer captures ride events from GPS and app&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #000000;&quot;&gt;&lt;b&gt;- &lt;/b&gt;Amazon MSK Kafka cluster ingests and buffers event streams&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="legend-step-1-group">
